# Application Configuration
APP_NAME=Enterprise Fraud Detection Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/v1
API_WORKERS=4

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database Configuration
DATABASE_URL=postgresql://fraud_user:fraud_password@localhost:5432/fraud_detection
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false

# AWS Configuration (for future phases)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_MODELS=fraud-detection-models-dev
S3_BUCKET_DATA=fraud-detection-data-dev

# Secrets Manager (for future phases)
AWS_SECRETS_MANAGER_ENABLED=false
AWS_SECRET_NAME=fraud-detection/dev

# CloudWatch (for future phases)
CLOUDWATCH_ENABLED=false
CLOUDWATCH_LOG_GROUP=/ecs/fraud-detection/api
CLOUDWATCH_NAMESPACE=FraudDetection

# Redis (optional, for future caching)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Request Timeout
REQUEST_TIMEOUT_SECONDS=30

# Monitoring
ENABLE_METRICS=true
ENABLE_TRACING=false
XRAY_ENABLED=false
